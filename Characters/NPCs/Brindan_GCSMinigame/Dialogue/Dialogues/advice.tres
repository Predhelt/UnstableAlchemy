[resource]
script = ExtResource("3_yd3o2")
dialogue_name = &"advice"
text = "Sure! To start, you can try equipping your blade and cutting some of those yellow flowers. Then you could sell a couple of the stems to me with some berries and I can perform the saturation if you don't want to attempt it yourself. There is a recipe book lying around that should tell you how to make the saturated stem. You'll need it for a speed potion."
