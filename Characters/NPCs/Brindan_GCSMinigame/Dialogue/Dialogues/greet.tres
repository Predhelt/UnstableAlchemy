[resource]
script = ExtResource("2_naugo")
dialogue_name = &"greet"
text = "Hey, My name is Brindan. I am known as a senior botanist.

I messed up my ankle trying to get out of the way of the falling rocks. It looks like we are stuck and we need to move that boulder up top to get out.

I can trade you some alchemy supplies or give you some advice. I also have some normalizing potions available for free that can help you go back to normal if you change somehow."
choices = Array[ExtResource("1_0womp")]([SubResource("Resource_1iaux")])
