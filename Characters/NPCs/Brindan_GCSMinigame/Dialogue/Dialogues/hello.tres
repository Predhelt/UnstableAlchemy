[resource]
script = ExtResource("3_q2nnr")
dialogue_name = &"hello"
text = "Hello, My name is Brindan. I am known as a senior botanist.

It looks like we are stuck and we need to move that boulder near the top to get out.

I can trade you some alchemy supplies or give you some advice. I also have some normalizing potions available for free that can help you go back to normal if you change somehow."
choices = Array[ExtResource("1_k2ao2")]([SubResource("Resource_1iaux"), SubResource("Resource_eu6b3")])
