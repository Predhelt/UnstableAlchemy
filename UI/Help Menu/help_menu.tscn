offset_right = 794.0
offset_bottom = 445.0
text = "Press WASD to move.

Walk near a plant or object to interact with it by pressing \"\".

You can get ingredients or other materials depending on how you interact with objects.

With your ingredients, you can craft new materials or potions using the tools in your inventory.

Drag ingredients from your inventory onto a tool to the right to add the ingredient to the tool.
From there, click on the check mark to open the crafting screen or click on the ingredient to remove it from the tool.

asdf"
autowrap_mode = 3
text_overrun_behavior = 4

