[node name="Label" type="Label" parent="VBoxContainer/HBoxContainer/TabContainer/PageMerger"]
layout_mode = 0
offset_left = 135.0
offset_top = 15.0
offset_right = 801.0
offset_bottom = 157.0
text = "The merger combines certain items together to produce a new item. This works by dragging items from the inventory onto the merger icon. Pressing the check mark when two or three items are in the merger will combine them and place the result in your inventory after a short crafting time. The items can be removed from the merger by pressing on them."
autowrap_mode = 3

