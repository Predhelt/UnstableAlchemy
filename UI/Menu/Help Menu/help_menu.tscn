[node name="PageMP" type="Control" parent="VBoxContainer/HBoxContainer/TabContainer"]
unique_name_in_owner = true
visible = false
layout_mode = 2
metadata/_tab_index = 3

[node name="Label" type="Label" parent="VBoxContainer/HBoxContainer/TabContainer/PageMP"]
layout_mode = 0
offset_left = 144.0
offset_top = 12.0
offset_right = 800.0
offset_bottom = 455.0
text = "Mortar and Pestle can be accessed from the inventory. drag an item from the inventory onto the mortar to add it to the mortar. Click on an item in the mortar to remove it. When at least one item is in the mortar, you can begin the minigame by pressing the check mark button.
The minigame will take the first item in the mortar to use for the minigame. To begin, press the \"Start\" button and use the arrow keys on the screen or the keyboard to input motions.
There are 2 main motions: crush and grind. Crush by going up and down. Grind by going left and right. If you do the inputs correctly, an icon will appear to represent the motion.
When 5 motions are made, if the process matches a possible recipe for the item, a new item will be produced and added to the inventory. "
autowrap_mode = 3

[node name="TextureRect" type="TextureRect" parent="VBoxContainer/HBoxContainer/TabContainer/PageMP"]
layout_mode = 0
offset_right = 40.0
offset_bottom = 40.0
texture = ExtResource("7_w7g1m")

[node name="PageCauldron" type="Control" parent="VBoxContainer/HBoxContainer/TabContainer"]
unique_name_in_owner = true
visible = false
layout_mode = 2
metadata/_tab_index = 4

[node name="Label" type="Label" parent="VBoxContainer/HBoxContainer/TabContainer/PageCauldron"]
layout_mode = 0
offset_left = 141.0
offset_top = 5.0
offset_right = 787.0
offset_bottom = 392.0
text = "Items can be added to the cauldron from the inventory. Drag an item onto the cauldron to add it to the cauldron.
When at least one item is in the cauldron, the crafting minigame can begin by pressing the check mark button on the cauldron. This opens a minigame window which shows the ingrediends that were added to the cauldron in the inventory as well as a fire icon representing bellows.
The minigame begins by pressing the \"start\" button. there will be a short countdown before the progress bar at the bottom will begin moving. The minigame works by adding an ingredient or using the bellows at a time interval until the process is complete. This can be done by either pressing the icons with the ingredients or bellows or pressing the hotkeys.
Once the minigame is complete, the producet item(s) will be added to the inventory and the minigame window will close."
autowrap_mode = 3

[node name="TextureRect" type="TextureRect" parent="VBoxContainer/HBoxContainer/TabContainer/PageCauldron"]
layout_mode = 0
offset_right = 40.0
offset_bottom = 40.0
texture = ExtResource("8_q88dc")

