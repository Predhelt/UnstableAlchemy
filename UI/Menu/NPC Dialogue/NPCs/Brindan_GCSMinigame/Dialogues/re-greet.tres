[resource]
script = ExtResource("2_57e22")
dialogue_name = &"re-greet"
text = "Oh, hello again. Did you figure out the Saturated Stem recipe yet?

You can get the gray juice by crushing up some red berries. I believe the order was crush-crush-grind-grind-grind.

That should help you break up the berries without losing too much of the essence you need for the saturation process."
