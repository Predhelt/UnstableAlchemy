; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Unstable Alchemy"
config/description="Gather, craft, and solve environmental puzzles."
config/version="0.2.17"
config/tags=PackedStringArray("git")
run/main_scene="uid://ckgxm2etu6kdm"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://cwkvxpniso0yh"

[audio]

buses/default_bus_layout="uid://bkfho6is2m6e"

[autoload]

Global="*res://global.gd"
UserVariables="*uid://dts5ftv4as2js"
MusicManager="*uid://xhmxjsdkghd"
AppConfig="*uid://cjke6crjg14a0"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/maaacks_input_remapping/plugin.cfg")

[global_group]

Pushable=""
Droppable="areas that you can drag and drop into"
Persist="Persistent Scenes between loads"
Crawlspace=""

