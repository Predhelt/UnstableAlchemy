[node name="Label" type="RichTextLabel" parent="VBoxContainer/TabContainer/TabBooks/HBoxContainer/PageContainer/PageBookRawMaterials" unique_id=516332756]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 20
text = "All commonly known raw materials and how to get them:

Red Berries from Red Berry Bushes

Blue Berries from Blue Berry Bushes
*Note: Blue Berry Bushes are usually not naturally found.

Yellow Petals from Yellow Flowers
Flower Stems from Yellow Flowers

- Green Herb Leaves from Green Herbs"

