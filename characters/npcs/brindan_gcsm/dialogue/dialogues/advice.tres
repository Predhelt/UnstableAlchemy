[resource]
script = ExtResource("3_vcitj")
dialogue_name = &"advice"
text = "Sure! I have a book that contains the recipe for a Strength Potion, as well as a few other related recipes. Help me out first, and I can give you the recipe book.

I think I dropped my \"introduction to green herbs\" book around here somewhere when I fell, if you haven't found it already. Get me a couple of bunches of green flakes and I will give you the recipe book and we can go from there."
choices = Array[ExtResource("1_ahwgl")]([SubResource("Resource_6rgy3")])
