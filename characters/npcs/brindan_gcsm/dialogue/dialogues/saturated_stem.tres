[resource]
script = ExtResource("2_mcwcs")
dialogue_name = &"saturated_stem"
text = "If you use your blade to cut the yellow flowers, you can get their stem. You can try crafting the saturated stem yourself from the recipe, or sell a couple of the stems to me with some berries and I can perform the saturation for you.

The gray juice recipe isn't in the book I gave you, but I can describe the process if you ask me."
choices = Array[ExtResource("1_a3qbw")]([SubResource("Resource_eyj5s"), SubResource("Resource_6yixi")])
